# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# -- Tripletex --
# Default points at Tripletex's TEST environment, which is safe to play with.
# Switch to https://tripletex.no/v2 for production.
TRIPLETEX_BASE_URL=https://api-test.tripletex.tech/v2

# Your group/organization-level API consumer token, issued by Tripletex.
TRIPLETEX_CONSUMER_TOKEN=your-tripletex-consumer-token

# Multi-company: JSON array of {name, employee_token} per company.
# - `name` is a free-form identifier you choose (e.g. "acme_no", "subsidiary_a").
#   Use it consistently when calling MCP tools with the `company` parameter.
# - Each entry may optionally override `consumer_token` and `base_url`,
#   e.g. to mix companies across the test and production environments.
TRIPLETEX_COMPANIES=[{"name":"company_a","employee_token":"your-employee-token"},{"name":"company_b","employee_token":"your-employee-token"}]

# Single-company alternative: set this INSTEAD of TRIPLETEX_COMPANIES.
# TRIPLETEX_EMPLOYEE_TOKEN=your-employee-token
