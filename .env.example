# Local dev (stdio mode) configuration template.
# Copy to `.env` and fill in real values — `.env` is gitignored.
# A hosted (Cloud Run) deployment reads these from Secret Manager instead;
# this file is purely for `python -m tripletex_mcp_multi --stdio` on your machine.

# Default to the TEST tenant so local dev never accidentally mutates prod data.
# Override to https://tripletex.no/v2 only when you specifically need prod.
TRIPLETEX_BASE_URL=https://api-test.tripletex.tech/v2

# Your group/organization-level API consumer token, issued by Tripletex.
TRIPLETEX_CONSUMER_TOKEN=your-consumer-token-here

# --- Option A: Single-company setup (simplest for dev) ---
# Tools that take a `company` param default to the only company; you may omit it.
TRIPLETEX_EMPLOYEE_TOKEN=your-employee-token-here

# --- Option B: Multi-company setup ---
# JSON array; `consumer_token` and `base_url` are optional per-entry overrides
# (e.g. to mix companies across the test and production environments).
# When set (with >1 entry), `company` becomes a required arg on every tool.
# `name` is a free-form identifier you choose; use it as the `company` parameter.
# TRIPLETEX_COMPANIES=[{"name":"company_a","employee_token":"token-a"},{"name":"company_b","employee_token":"token-b"}]
